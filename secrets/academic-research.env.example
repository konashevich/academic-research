# Academic Research extension — local credentials template
# Copy to secrets/academic-research.env and fill in values.
# secrets/ is gitignored; never commit the .env file.
#
# Used by: Writing Hub → Infrastructure step
# Sources on this machine (for reference):
#   Zotero: /mnt/merged_ssd/MCP/zotero-mcp/.env.local
#   MCP URLs: ~/.cursor/mcp.json and paper project .vscode/mcp.json

# --- Required (Zotero) ---
ZOTERO_API_KEY=
ZOTERO_LIBRARY_ID=
ZOTERO_LIBRARY_TYPE=user

# --- Optional (Cursor agent ranking in citation search) ---
# Get from https://cursor.com/dashboard/integrations
CURSOR_API_KEY=

# --- Optional (OpenAlex polite pool) ---
OPENALEX_EMAIL=

# --- MCP connectivity (external / legacy Docker mode) ---
# Bundled mode ignores these and starts local uvx/uv servers instead.
ACADEMIC_MCP_HOST=127.0.0.1
ZOTERO_MCP_PORT=9180
SCHOLAR_MCP_PORT=3847

# --- Extension settings (optional overrides) ---
# academicResearch.mcpMode=bundled
# academicResearch.setupComplete=false
